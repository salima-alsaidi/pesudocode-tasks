            END IF

        END METHOD



        CALCULATE_TOTAL_PRICE()

            SET TOTAL TO AGREED_PRICE

            DISPLAY "BASE PRICE: "
            DISPLAY AGREED_PRICE


            REPEAT FROM F IN ADDON_FEATURES

                DISPLAY F.FEATURE_NAME
                DISPLAY F.GET_COST()

                SET TOTAL TO TOTAL + F.GET_COST()

            END REPEAT


            DISPLAY "TOTAL PRICE:"
            DISPLAY TOTAL

            RETURN TOTAL

        END METHOD



        COMPLETE_SALE()

            IF VEHICLE.CHECK_AVAILABILITY() = "AVAILABLE" THEN

                VEHICLE.MARK_AS_SOLD()

                CUSTOMER.ADD_PURCHASE(SELF)

                SET STATUS TO "COMPLETED"

                DISPLAY "SALE COMPLETED"

            ELSE

                DISPLAY "VEHICLE NOT AVAILABLE"

            END IF

        END METHOD


    END METHODS

