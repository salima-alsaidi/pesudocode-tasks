CLASS EVENT

    ATTRIBUTE
        EVENT_ID : NUMBER
        EVENT_DATE : TEXT
        BUDGET : NUMBER
        TOTAL_COST : NUMBER
        TASKS : LIST OF TASK
        GUESTS : LIST OF GUEST


    CONSTRUCTOR(ID : NUMBER, DATE : TEXT, B : NUMBER)

        SET EVENT_ID TO ID
        SET EVENT_DATE TO DATE
        SET BUDGET TO B
        SET TOTAL_COST TO 0
        SET TASKS TO EMPTY LIST
        SET GUESTS TO EMPTY LIST

    END CONSTRUCTOR



    METHODS



        ADD_TASK(T : TASK)

            IF TASKS DOES NOT CONTAIN T THEN

                ADD T TO TASKS

                SET TOTAL_COST TO TOTAL_COST + T.GET_COST()

            ELSE

                DISPLAY "TASK ALREADY EXISTS"

            END IF

        END METHOD



        ADD_GUEST(G : GUEST)

            ADD G TO GUESTS

        END METHOD



        CHECK_BUDGET()

            IF TOTAL_COST <= BUDGET THEN

                RETURN TRUE

            ELSE

                RETURN FALSE

            END IF

        END METHOD



        GET_REMAINING_BUDGET()

            RETURN BUDGET - TOTAL_COST

        END METHOD



        DISPLAY_EVENT()

            DISPLAY EVENT_ID
            DISPLAY EVENT_DATE
            DISPLAY TOTAL_COST
            DISPLAY TASKS
            DISPLAY GUESTS

        END METHOD


    END METHODS

END CLASS



