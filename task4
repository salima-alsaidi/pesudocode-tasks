        CLAIM_ID : NUMBER
        CLAIM_DATE : TEXT
        AMOUNT : NUMBER
        STATUS : TEXT
        COVERAGE_TYPE : TEXT

    CONSTRUCTOR(CID : NUMBER, CDATE : TEXT, A : NUMBER, ST : TEXT, COV : TEXT)
        SET CLAIM_ID TO CID
        SET CLAIM_DATE TO CDATE
        SET AMOUNT TO A
        SET STATUS TO ST
        SET COVERAGE_TYPE TO COV
    END CONSTRUCTOR


    METHODS

        UPDATE_STATUS(NEW_STATUS : TEXT)

            IF STATUS = "PENDING" THEN

                IF NEW_STATUS = "APPROVED" OR NEW_STATUS = "REJECTED" THEN
                    SET STATUS TO NEW_STATUS
                ELSE
                    DISPLAY "INVALID STATUS CHANGE"
                END IF

            ELSE IF STATUS = "APPROVED" THEN

                IF NEW_STATUS = "PAID" THEN
                    SET STATUS TO NEW_STATUS
                ELSE
                    DISPLAY "INVALID STATUS CHANGE"
                END IF

            ELSE
                DISPLAY "STATUS CANNOT BE CHANGED"

            END IF

        END METHOD


        GET_CLAIM_AMOUNT()
            RETURN AMOUNT
        END METHOD


        CHECK_CLAIM_LIMIT(COVERAGE_LIMIT : NUMBER)

            IF AMOUNT <= COVERAGE_LIMIT THEN
                RETURN TRUE
            ELSE
                RETURN FALSE
            END IF

        END METHOD


    END METHODS

END CLASS



