CLASS DEVELOPER

    ATTRIBUTE
        DEVELOPERID : NUMBER
        NAME : TEXT
        CAPACITY : NUMBER
        ASSIGNEDTASKS : LIST OF TASK

    CONSTRUCTOR (ID, N, C)
        SET DEVELOPERID TO ID
        SET NAME TO N
        SET CAPACITY TO C
        SET ASSIGNEDTASKS TO EMPTY LIST
    END CONSTRUCTOR

    METHODS

        CAN_ASSIGN()
            IF SIZE OF ASSIGNEDTASKS < CAPACITY THEN
                RETURN TRUE
            ELSE
                RETURN FALSE
            END IF
        END METHOD

        ASSIGN_TASK(TASK)
            IF SIZE OF ASSIGNEDTASKS < CAPACITY THEN
                ADD TASK TO ASSIGNEDTASKS
            ELSE
                DISPLAY "CAPACITY EXCEEDED"
            END IF
        END METHOD

    END METHODS

END CLASS


CLASS TASK

    ATTRIBUTE
        TASKID : NUMBER
        TITLE : TEXT
        STATUS : TEXT
        DEVELOPER : DEVELOPER

    CONSTRUCTOR (ID, T, DEV)
        SET TASKID TO ID
        SET TITLE TO T
        SET DEVELOPER TO DEV
        SET STATUS TO "TO DO"
    END CONSTRUCTOR

    METHODS

        UPDATE_STATUS(NEWSTATUS)
            IF STATUS = "TO DO" AND NEWSTATUS = "IN PROGRESS" THEN
                SET STATUS TO NEWSTATUS
            ELSE IF STATUS = "IN PROGRESS" AND NEWSTATUS = "DONE" THEN
                SET STATUS TO NEWSTATUS
            ELSE IF STATUS = "DONE" AND NEWSTATUS = "COMPLETED" THEN
                SET STATUS TO NEWSTATUS
            ELSE
                DISPLAY "INVALID STATUS TRANSITION"
            END IF
        END METHOD

        MARK_COMPLETE()
            IF STATUS = "DONE" THEN
                SET STATUS TO "COMPLETED"
            ELSE
                DISPLAY "TASK NOT READY"
            END IF
        END METHOD

    END METHODS

END CLASS


CLASS BACKLOG

    ATTRIBUTE
        TASKLIST : LIST OF TASK

    CONSTRUCTOR ()
        SET TASKLIST TO EMPTY LIST
    END CONSTRUCTOR

    METHODS

        ADD_TASK(TASK)
            ADD TASK TO TASKLIST
        END METHOD

        GET_NEXT_TASK()
            RETURN FIRST ITEM OF TASKLIST
        END METHOD

    END METHODS

END CLASS


CLASS SPRINT

    ATTRIBUTE
        SPRINTID : NUMBER
        TASKS : LIST OF TASK

    CONSTRUCTOR (ID)
        SET SPRINTID TO ID
        SET TASKS TO EMPTY LIST
    END CONSTRUCTOR

    METHODS

        ADD_TASK(TASK)
            ADD TASK TO TASKS
        END METHOD

        CALCULATE_PROGRESS()
            SET DONE TO 0

            REPEAT FROM 1 TO SIZE OF TASKS
                IF TASKS[INDEX].STATUS = "COMPLETED" THEN
                    SET DONE TO DONE + 1
                END IF
            END REPEAT

            IF SIZE OF TASKS > 0 THEN
                RETURN (DONE / SIZE OF TASKS) * 100
            ELSE
                RETURN 0
            END IF
        END METHOD

    END METHODS

END CLASS


