        SET TYPE TO T
        SET DATE TO D
        SET WORKER TO W
        SET CROP TO C
        SET WATERAMOUNT TO WATER
    END CONSTRUCTOR

    METHODS

        VALIDATE_WATER()
            IF WATERAMOUNT <= CROP.WATERNEED THEN
                DISPLAY "WATERING OK"
            ELSE
                DISPLAY "INSUFFICIENT WATER"
            END IF
        END METHOD

    END METHODS

